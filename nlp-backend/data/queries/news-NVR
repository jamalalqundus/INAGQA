PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dbo: <http://dbpedia.org/ontology/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX cisqa: <http://localhost:8890/ontologies/2020/9/cisqa20/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX dbp: <http://dbpedia.org/property/>
PREFIX dbr: <http://dbpedia.org/resource/>

            SELECT DISTINCT
            ?iri
            ?lastModified
            ?date
            ?title
            ?author
            ?language
            ?effDate
            ?capitalMeasure
            ?votingRights
            
            FROM <http://localhost:8890/ontologies/2020/9/cisqa20/>
            WHERE {
                ?iri a cisqa:dgap_message ;
                   cisqa:isDgapCategory "NVR" .


                ?iri cisqa:isAboutCompany ?company .

                ?company rdfs:label ?lbl .
                FILTER regex( ?lbl,"%(comp)s", "i")

                OPTIONAL{?iri cisqa:wasLastModified ?lastModified .}
                OPTIONAL{?iri cisqa:onDate ?date .}
                OPTIONAL{?iri cisqa:hasTitle ?title .}
                OPTIONAL{?iri cisqa:hasAuthor ?author .}
                OPTIONAL{?iri cisqa:isOfLanguage ?language .}
                OPTIONAL{?iri cisqa:hasEffectiveDate ?effDate .}
                OPTIONAL{?iri cisqa:hasCapitalMeasure ?capitalMeasure .}
                OPTIONAL{?iri cisqa:hasTotalVotingRights ?votingRights .}
            }